# ─────────────────────────────────────────────────────────────────────────────
# Verda environment variables. Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only. Bypasses RLS — used by the delete-my-data endpoint to remove the
# Supabase auth user. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Postgres connection (Project Settings → Database → Connection string)
# DATABASE_URL = pooled (PgBouncer, port 6543) for app runtime.
# DIRECT_URL   = direct (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# Anthropic Claude (OPTIONAL). If absent, insights fall back to the deterministic
# rule engine so the demo never fails.
ANTHROPIC_API_KEY=""

# App URL (used for auth redirect callbacks)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── v2 differentiator features (ALL OPTIONAL — everything works without them) ──
# Electricity Maps — live grid carbon intensity for the carbon-aware "eco mode".
# Without a key, the app shows a neutral fallback chip. Get a free key at
# https://www.electricitymaps.com/free-tier
ELECTRICITY_MAPS_API_KEY=""
# Your Electricity Maps zone (e.g. IN-WE, IN-SO, IN-NO, IN-EA). Default: IN-WE
ELECTRICITY_MAPS_ZONE="IN-WE"

# Climatiq — live emission factors. Without a key, the seeded DB factors are used
# (deterministic). https://www.climatiq.io/
CLIMATIQ_API_KEY=""

# Domain checked for green hosting (Green Web Foundation, no key needed).
# Defaults to the host of NEXT_PUBLIC_SITE_URL.
GREEN_CHECK_DOMAIN=""
